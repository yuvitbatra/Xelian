# Local development (docker run -d --name xelian-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=xelian -p 5433:5432 postgres:16-alpine)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/xelian

