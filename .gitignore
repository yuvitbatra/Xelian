/target
.superpowers/

# Built package archives (produced by `xelian push`), but NOT the committed
# golden interop fixture the registry/CLI checksum tests depend on.
*.xelian
!tests/golden/fixture.xelian

# Python (registry backend + SDK)
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Secrets — real values only ever go in a local .env or the Render
# dashboard, never in git. .env.example (checked in) documents the keys.
.env
.env.*
!.env.example
